# .env.example
# Copy this file to .env.local and fill the values (do NOT commit actual secrets).
# Example environment variables required by the project.

# Upstream chat/Lambda URL the Next.js API will forward requests to
CHAT_UPSTREAM_URL=

# (Optional) Allowed origin for CORS; set to your frontend domain in production
ALLOWED_ORIGIN=

# Additional optional keys you may want to define per environment
# UPSTREAM_API_KEY=
# NEXT_PUBLIC_ANALYTICS_ID=
