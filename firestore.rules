rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Chat history
    match /chats/{chatId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['userId', 'title', 'messages'])
                    && request.resource.data.userId is string
                    && request.resource.data.title is string;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['messages', 'updatedAt']);
      allow delete: if true;
    }

    // Feedback (like/dislike)
    match /feedback/{feedbackId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasAll(['type', 'userId'])
                    && request.resource.data.type in ['like', 'dislike']
                    && request.resource.data.userId is string;
    }
  }
}
